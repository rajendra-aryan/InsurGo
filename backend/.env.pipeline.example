# ─── Server ───────────────────────────────────────────────
PORT=5000
NODE_ENV=development
FRONTEND_URL=http://localhost:5173

# ─── MongoDB ──────────────────────────────────────────────
MONGODB_URI=mongodb://username:password@mongo:27017/insurgo?authSource=admin

# ─── JWT ──────────────────────────────────────────────────
JWT_SECRET=your_super_secret_jwt_key_here
JWT_EXPIRES_IN=7d

# ─── ML Service (FastAPI) ─────────────────────────────────
ML_SERVICE_URL=http://ml:8000/insurance-decision
ML_HEALTH_URL=http://ml:8000/health
ML_SERVICE_TIMEOUT_MS=4000
ML_MODEL_VERSION=premium_model1B.pkl

# ─── OpenWeather API ──────────────────────────────────────
OPENWEATHER_API_KEY=your_openweather_api_key
OPENWEATHER_BASE_URL=https://api.openweathermap.org/data/2.5

# ─── WAQI API ─────────────────────────────────────────────
WAQI_API_KEY=your_waqi_api_key
WAQI_BASE_URL=https://api.waqi.info

# ─── Razorpay Sandbox ─────────────────────────────────────
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_secret
RAZORPAY_ACCOUNT_NUMBER=your_razorpay_account_number

# ─── Trigger Thresholds ───────────────────────────────────
RAIN_THRESHOLD_MM=60
AQI_THRESHOLD=300
CURFEW_TRIGGER_ENABLED=false

# ─── Cron ─────────────────────────────────────────────────
TRIGGER_CRON=*/15 * * * *

# ─── Claims Rate Limiting ─────────────────────────────────
CLAIMS_RATE_LIMIT_WINDOW_MS=60000
CLAIMS_RATE_LIMIT_MAX=30
