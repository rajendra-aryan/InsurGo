# ─── Server ───────────────────────────────────────────────
PORT=5000
NODE_ENV=development
FRONTEND_URL=http://localhost:8080

# ─── MongoDB Atlas ────────────────────────────────────────
MONGODB_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/insurgo?retryWrites=true&w=majority

# ─── JWT ──────────────────────────────────────────────────
JWT_SECRET=your_super_secret_jwt_key_here
JWT_EXPIRES_IN=7d

# ─── OpenWeather API ──────────────────────────────────────
OPENWEATHER_API_KEY=your_openweather_api_key
OPENWEATHER_BASE_URL=https://api.openweathermap.org/data/2.5

# ─── WAQI (World Air Quality Index) API ──────────────────
# Free key at: https://aqicn.org/data-platform/token/
WAQI_API_KEY=your_waqi_api_key
WAQI_BASE_URL=https://api.waqi.info

# ─── Razorpay Sandbox ─────────────────────────────────────
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_secret
RAZORPAY_ACCOUNT_NUMBER=your_razorpay_account_number

# ─── Trigger Thresholds ───────────────────────────────────
RAIN_THRESHOLD_MM=60
AQI_THRESHOLD=300
CURFEW_TRIGGER_ENABLED=false

# ─── Cron ─────────────────────────────────────────────────
# How often to poll APIs (cron syntax). Default: every 15 minutes
TRIGGER_CRON=*/15 * * * *
